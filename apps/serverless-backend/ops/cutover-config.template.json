{
  "environment": "production",
  "changeWindow": {
    "startIso": "YYYY-MM-DDTHH:mm:ssZ",
    "endIso": "YYYY-MM-DDTHH:mm:ssZ",
    "approver": "team-or-user"
  },
  "routing": {
    "legacyTarget": "LEGACY_TARGET_PLACEHOLDER",
    "serverlessTarget": "SERVERLESS_TARGET_PLACEHOLDER",
    "canaryPercentages": [5, 25, 50, 100],
    "holdMinutesPerStep": 15
  },
  "aws": {
    "region": "us-east-1",
    "stepFunctionArn": "arn:aws:states:REGION:ACCOUNT_ID:stateMachine:STATE_MACHINE_NAME",
    "lambdaArns": {
      "validateWebhook": "arn:aws:lambda:REGION:ACCOUNT_ID:function:validate-webhook",
      "processTransferLeg": "arn:aws:lambda:REGION:ACCOUNT_ID:function:process-transfer-leg",
      "compensateTransferLeg": "arn:aws:lambda:REGION:ACCOUNT_ID:function:compensate-transfer-leg"
    },
    "dynamoTableName": "BankingCore"
  },
  "alarmThresholds": {
    "failedExecutionsMaxPer5Min": 1,
    "compensationRequiredMaxPer5Min": 1,
    "webhookValidationFailuresMaxPer5Min": 5
  },
  "rollback": {
    "owner": "on-call-team",
    "triggerErrorRatePercent": 2.0,
    "triggerP99LatencyMs": 2000,
    "maxReconciliationMismatchCount": 0
  }
}
