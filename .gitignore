apps/api/__pycache__/
apps/api/**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
apps/api/venv/
apps/api/env/
apps/api/ENV/
apps/api/.venv/

# Flask
apps/api/instance/
apps/api/.webassets-cache

# Python distributions
